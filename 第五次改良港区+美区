get_weighted_score() {
  local ip="$1"
  local history_file="$2"
  grep "^$ip " "$history_file" 2>/dev/null | awk '{
    n=NF;
    if(n>=4) print $(n-2) + $(n-1) + ($n*2);
    else if(n==3) print $(n-1) + ($n*2);
    else if(n==2) print $n*2;
    else print 0;
  }'
}

build_weighted_rank() {
  local ALL_SCORED="$1"
  local HISTORY_FILE="$2"
  local OUT_FILE="$3"
  local LABEL="$4"
  > "$OUT_FILE"
  while read -r LINE; do
    local TODAY_SCORE IP W_SCORE
    TODAY_SCORE=$(echo "$LINE" | awk '{print $1}')
    IP=$(echo "$LINE" | awk '{print $2}')
    [ -z "$IP" ] && continue
    W_SCORE=$(get_weighted_score "$IP" "$HISTORY_FILE")
    [ -z "$W_SCORE" ] && W_SCORE=0
    echo "$W_SCORE $IP $TODAY_SCORE" >> "$OUT_FILE"
  done <<< "$ALL_SCORED"
  sort -rn "$OUT_FILE" -o "$OUT_FILE"
  echo "$TS [INFO]  $LABEL 加权排序完成，前5名:"
  head -5 "$OUT_FILE" | while read -r W I S; do
    echo "$TS [INFO]    加权总分=${W}  IP=${I}  今日分=${S}"
  done
}

rescore_from_last_result() {
