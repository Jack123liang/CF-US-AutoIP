run_health_and_score() {
  local POOL_FILE="$1"
  local CHECK_RESULT="$2"
  local HISTORY_FILE="$3"
  local LABEL="$4"
  local REGION_FILTER="$5"
  local NEW_COUNT_FILE="/tmp/cfst_new_count_${LABEL,,}.txt"

  if [ ! -f "$POOL_FILE" ] || [ ! -s "$POOL_FILE" ]; then
    echo "$TS [WARN]  $LABEL 池为空，跳过"
    > "/tmp/all_scored_${LABEL,,}.txt"
    echo "0" > "/tmp/new_count_display_${LABEL,,}.txt"
    return 1
  fi

  local TOTAL
  TOTAL=$(wc -l < "$POOL_FILE")
  echo "$TS [INFO]  $LABEL 池共 ${TOTAL} 个IP，开始健康检测..."

  "$CFST_BIN" \
    -f "$POOL_FILE" \
    -tl 9999 -tlr 100 -sl 0 -dn 999 -dt 3 -tp 443 \
    -o "$CHECK_RESULT"

  if [ ! -f "$CHECK_RESULT" ]; then
    echo "$TS [ERROR] $LABEL 健康检测无结果"
    > "/tmp/all_scored_${LABEL,,}.txt"
    echo "0" > "/tmp/new_count_display_${LABEL,,}.txt"
    return 1
  fi

  local PASS
  PASS=$(tail -n +2 "$CHECK_RESULT" | wc -l)
  echo "$TS [INFO]  $LABEL 通过检测: ${PASS} 个IP"

  echo "$TS [INFO]  $LABEL 开始综合评分..."
  local ALL_SCORED
  ALL_SCORED=$(tail -n +2 "$CHECK_RESULT" \
    | awk -F',' -v rf="$REGION_FILTER" '{
        ip=$1; loss=$4+0; rtt=$5+0; speed=$6+0; region=$7;
        gsub(/:[0-9]+$/, "", ip);
        gsub(/[^A-Za-z]/, "", region);
        score=0;
        if (speed >= 40) score += 100;
        else if (speed >= 25) score += 80;
        else if (speed >= 10) score += 40;
        else if (speed >= 5)  score += 10;
        else score -= 50;
        if (rtt < 150)       score += 20;
        else if (rtt < 250)  score += 15;
        else if (rtt < 400)  score += 5;
        else score -= 20;
        if (loss < 0.1)      score += 30;
        else if (loss < 1)   score += 10;
        else score -= 100;
        if (region ~ rf)     score += 5;
        print score, ip
      }' \
    | sort -rn)

  echo "$TS [INFO]  $LABEL 今日评分Top3:"
  echo "$ALL_SCORED" | head -3 | while read -r S I; do
    echo "$TS [INFO]    → ${I}  当日分=${S}"
  done

  local ALL_IPS RETURNED_IPS TOTAL_IPS RATIO GLOBAL_FAIL
  ALL_IPS=$(cat "$POOL_FILE")
  RETURNED_IPS=$(echo "$ALL_SCORED" | grep -c '[0-9]' 2>/dev/null || echo 0)
  TOTAL_IPS=$(echo "$ALL_IPS" | wc -l)
  RATIO=$(awk -v r="$RETURNED_IPS" -v t="$TOTAL_IPS" \
    'BEGIN{if(t==0) print 0; else printf "%.2f", r/t}')

  if awk "BEGIN{exit !($RATIO < 0.5)}"; then
    echo "$TS [WARN]  $LABEL 检测返回率异常（${RATIO}），跳过未返回惩罚"
    GLOBAL_FAIL=1
  else
    GLOBAL_FAIL=0
    echo "$TS [INFO]  $LABEL 检测返回率正常（${RATIO}），处理未返回IP..."
  fi

  touch "$HISTORY_FILE"
  local MISSING_IPS
  MISSING_IPS=$(comm -23 \
    <(echo "$ALL_IPS" | sort) \
    <(echo "$ALL_SCORED" | awk '{print $2}' | sort))

  while read -r ip; do
    [ -z "$ip" ] && continue
    [ "$GLOBAL_FAIL" -eq 1 ] && continue
    local FAIL_COUNT PENALTY
    FAIL_COUNT=$(grep "^$ip " "$HISTORY_FILE" 2>/dev/null | awk '{
      count=0; for(i=2;i<=NF;i++) if($i+0 < 0) count++; print count}')
    [ -z "$FAIL_COUNT" ] && FAIL_COUNT=0
    PENALTY=$(awk -v c="$FAIL_COUNT" 'BEGIN{
      if(c==0) print -50; else if(c==1) print -80;
      else if(c==2) print -120; else print -200;}')
    ALL_SCORED="${ALL_SCORED}"$'\n'"${PENALTY} ${ip}"
    echo "$TS [INFO]  $LABEL 未返回惩罚: ${ip} (第${FAIL_COUNT}次失败, 扣分=${PENALTY})"
  done <<< "$MISSING_IPS"

  ALL_SCORED=$(echo "$ALL_SCORED" | grep -v '^$' | sort -rn)

  echo "$TS [INFO]  $LABEL 更新历史评分文件..."
  local SCORED_TMP="/tmp/scored_${LABEL,,}_$$.txt"
  echo "$ALL_SCORED" > "$SCORED_TMP"
  while read -r SCORE IP; do
    [ -z "$IP" ] && continue
    if grep -q "^$IP " "$HISTORY_FILE"; then
      local OLD NEW_RECORD
      OLD=$(grep "^$IP " "$HISTORY_FILE" | awk '{$1=""; print $0}' | xargs)
      NEW_RECORD="$IP $OLD $SCORE"
      NEW_RECORD=$(echo "$NEW_RECORD" | awk '{
        n=NF;
        if(n>4){ printf $1; for(i=n-2;i<=n;i++) printf " "$i; print ""}
        else print $0}')
      sed -i "s|^$IP .*|$NEW_RECORD|" "$HISTORY_FILE"
    else
      echo "$IP $SCORE" >> "$HISTORY_FILE"
    fi
  done < "$SCORED_TMP"
  rm -f "$SCORED_TMP"

  echo "$TS [INFO]  $LABEL 加权综合评分Top5（历史×1+历史×1+今日×2）:"
  awk '{
    ip=$1; n=NF;
    if(n>=4) w=$(n-2) + $(n-1) + ($n*2);
    else if(n==3) w=$(n-1) + ($n*2);
    else w=$n*2;
    print w, ip, $n
  }' "$HISTORY_FILE" | sort -rn | head -5 | while read -r W I S; do
    echo "$TS [INFO]    加权总分=${W}  IP=${I}  今日分=${S}"
  done

  local NEW_COUNT=0
  [ -f "$NEW_COUNT_FILE" ] && NEW_COUNT=$(cat "$NEW_COUNT_FILE" | tr -d '[:space:]')
  [ -z "$NEW_COUNT" ] && NEW_COUNT=0

  if [ "$NEW_COUNT" -gt 0 ]; then
    echo "$TS [INFO]  $LABEL 动态平衡：今日新增${NEW_COUNT}个，末位淘汰${NEW_COUNT}个..."
    awk '{
      ip=$1; n=NF;
      if(n>=4) w=($(n-2)+$(n-1)+($n*2))/4;
      else if(n==3) w=($(n-1)+($n*2))/3;
      else w=$n;
      printf "%s %.2f\n", ip, w
    }' "$HISTORY_FILE" | sort -k2,2n > /tmp/ip_weighted_rank_${LABEL,,}.txt

    local WORST_IPS COUNT EXTRA
    WORST_IPS=$(awk -v min="$MIN_SCORE" '$2 < min {print $1}' \
      /tmp/ip_weighted_rank_${LABEL,,}.txt | head -n "$NEW_COUNT")
    COUNT=$(echo "$WORST_IPS" | grep -c '[0-9]' 2>/dev/null || echo 0)
    if [ "$COUNT" -lt "$NEW_COUNT" ]; then
      EXTRA=$(awk '{print $1}' /tmp/ip_weighted_rank_${LABEL,,}.txt | head -n "$NEW_COUNT")
      WORST_IPS=$(printf "%s\n%s" "$WORST_IPS" "$EXTRA" | sort -u | head -n "$NEW_COUNT")
    fi

    while read -r BAD_IP; do
      [ -z "$BAD_IP" ] && continue
      sed -i "/^${BAD_IP}$/d" "$POOL_FILE"
      sed -i "/^${BAD_IP} /d" "$HISTORY_FILE"
      echo "$TS [INFO]  $LABEL 已淘汰低质量IP: $BAD_IP"
    done <<< "$WORST_IPS"

    rm -f /tmp/ip_weighted_rank_${LABEL,,}.txt /tmp/cfst_new_count_${LABEL,,}.txt
    local AFTER_BAL
    AFTER_BAL=$(wc -l < "$POOL_FILE")
    echo "$TS [INFO]  $LABEL 动态平衡后池子: ${AFTER_BAL} 个"
  else
    echo "$TS [INFO]  $LABEL 今日无新增IP，跳过动态平衡"
  fi

  echo "$ALL_SCORED" > "/tmp/all_scored_${LABEL,,}.txt"
  echo "$NEW_COUNT" > "/tmp/new_count_display_${LABEL,,}.txt"
  return 0
}

