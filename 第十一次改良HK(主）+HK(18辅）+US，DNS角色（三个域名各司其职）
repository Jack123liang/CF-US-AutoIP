ALL_SCORED=$(tail -n +2 "$RESULT_HEALTH" \
  | awk -F',' -v rf="$REGION_FILTER" '{
      ip=$1; loss=$4+0; rtt=$5+0; speed=$6+0; region=$7;
      gsub(/:[0-9]+$/,"",ip); gsub(/[^A-Za-z]/,"",region);
      if      (speed < 5)  s_score=30;
      else if (speed < 10) s_score=40;
      else if (speed < 15) s_score=50;
      else if (speed < 20) s_score=60;
      else if (speed < 25) s_score=70;
      else if (speed < 30) s_score=80;
      else if (speed < 35) s_score=90;
      else if (speed < 40) s_score=100;
      else s_score=100+int((speed-40)/5)*10;
      if      (rtt < 30) r_score=50;
     else if (rtt < 50) r_score=45;
     else if (rtt < 70) r_score=40;
      else if (rtt < 90) r_score=35;
      else if (rtt < 110) r_score=30;
      else if (rtt < 150) r_score=25;
      else if (rtt < 200) r_score=20;
      else if (rtt < 300) r_score=15;
      else if (rtt < 350) r_score=10;
      else if (rtt < 400) r_score=5;
      else                r_score=-20;
      if      (loss < 0.1) l_score=30;
      else if (loss < 1)   l_score=10;
      else                 l_score=-100;
      reg_score=(region~rf)?5:0;
      print s_score+r_score+l_score+reg_score, ip
    }' | sort -rn)

echo "$(TS) [INFO]  US今日评分Top5:"
echo "$ALL_SCORED" | head -5 | while read -r S I; do
  echo "$(TS) [INFO]    → ${I}  当日分=${S}"
done

ALL_IPS=$(cat "$ACCUM_FILE")
RETURNED=$(echo "$ALL_SCORED" | grep -c '[0-9]' 2>/dev/null || echo 0)
TOTAL_IPS=$(echo "$ALL_IPS" | wc -l)
RATIO=$(awk -v r="$RETURNED" -v t="$TOTAL_IPS" 'BEGIN{if(t==0)print 0;else printf "%.2f",r/t}')
if awk "BEGIN{exit !($RATIO < 0.5)}"; then
  echo "$(TS) [WARN]  返回率异常（${RATIO}），跳过未返回惩罚"; GLOBAL_FAIL=1
else
  GLOBAL_FAIL=0
  echo "$(TS) [INFO]  返回率正常（${RATIO}），处理未返回IP..."
fi

touch "$HISTORY_FILE"
MISSING=$(comm -23 <(echo "$ALL_IPS"|sort) <(echo "$ALL_SCORED"|awk '{print $2}'|sort))
while read -r ip; do
  [ -z "$ip" ] && continue
  [ "$GLOBAL_FAIL" -eq 1 ] && continue
  FAIL_COUNT=$(grep "^$ip " "$HISTORY_FILE" 2>/dev/null | awk '{c=0;for(i=2;i<=NF;i++)if($i+0<0)c++;print c}')
  [ -z "$FAIL_COUNT" ] && FAIL_COUNT=0
  PENALTY=$(awk -v c="$FAIL_COUNT" 'BEGIN{if(c==0)print -50;else if(c==1)print -80;else if(c==2)print -120;else print -200;}')
  ALL_SCORED="${ALL_SCORED}"$'\n'"${PENALTY} ${ip}"
  echo "$(TS) [INFO]  未返回惩罚: ${ip} (第${FAIL_COUNT}次, 扣${PENALTY})"
done <<< "$MISSING"
ALL_SCORED=$(echo "$ALL_SCORED" | grep -v '^$' | sort -rn)

echo "$(TS) [INFO]  ── 第六步：更新历史评分 + 写出加权榜 ─────────"
SCORED_TMP="/tmp/scored_us_$$.txt"
echo "$ALL_SCORED" > "$SCORED_TMP"
while read -r SCORE IP; do
  [ -z "$IP" ] && continue
  if grep -q "^$IP " "$HISTORY_FILE"; then
    OLD=$(grep "^$IP " "$HISTORY_FILE" | awk '{$1="";print $0}' | xargs)
    NEW_REC="$IP $OLD $SCORE"
    NEW_REC=$(echo "$NEW_REC" | awk '{n=NF;if(n>4){printf $1;for(i=n-2;i<=n;i++)printf " "$i;print ""}else print $0}')
    sed -i "s|^$IP .*|$NEW_REC|" "$HISTORY_FILE"
  else
    echo "$IP $SCORE" >> "$HISTORY_FILE"
  fi
done < "$SCORED_TMP"
rm -f "$SCORED_TMP"

HEALTH_PASS_IPS=$(tail -n +2 "$RESULT_HEALTH" \
  | awk -F',' -v min="$HEALTH_SPEED_MIN" '$6+0>=min{print $1}' \
  | sed 's/:[0-9]*$//' \
  | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' | sort -u)
HEALTH_PASS_COUNT=$(echo "$HEALTH_PASS_IPS" | grep -c '[0-9]' 2>/dev/null || echo 0)
echo "$(TS) [INFO]  健康检测速度≥${HEALTH_SPEED_MIN}MB/s: ${HEALTH_PASS_COUNT} 个IP进入加权榜"

echo "$(TS) [INFO]  US加权综合评分Top5（历史×1+历史×1+今日×2）:"
awk '{
  ip=$1; n=NF;
  if(n>=4) w=$(n-2)+$(n-1)+($n*2);
  else if(n==3) w=$(n-1)+($n*2);
  else w=$n*2;
  print w, ip, $n
}' "$HISTORY_FILE" | sort -rn | while read -r W I S; do
  echo "$HEALTH_PASS_IPS" | grep -qx "$I" && echo "$W $I $S"
done > "$WEIGHTED_OUT"

head -5 "$WEIGHTED_OUT" | while read -r W I S; do
  echo "$(TS) [INFO]    加权总分=${W}  IP=${I}  今日分=${S}"
done
echo "$(TS) [INFO]  加权榜已写出: $WEIGHTED_OUT（共 $(wc -l < "$WEIGHTED_OUT") 条）"

echo "$(TS) [INFO]  ── 第七步：动态平衡 ─────────────────────────"
NEW_COUNT_VAL=0
[ -f "$NEW_COUNT_FILE" ] && NEW_COUNT_VAL=$(cat "$NEW_COUNT_FILE" | tr -d '[:space:]')
[ -z "$NEW_COUNT_VAL" ] && NEW_COUNT_VAL=0
CURRENT_POOL=$(wc -l < "$ACCUM_FILE")
echo "$(TS) [INFO]  当前池: ${CURRENT_POOL} 个  阈值: ${BALANCE_THRESHOLD} 个  今日新增: ${NEW_COUNT_VAL} 个"

if [ "$CURRENT_POOL" -lt "$BALANCE_THRESHOLD" ]; then
  echo "$(TS) [INFO]  未达阈值，跳过动态平衡（累积阶段）"
elif [ "$NEW_COUNT_VAL" -le 0 ]; then
  echo "$(TS) [INFO]  今日无新增IP，跳过动态平衡"
else
  REMOVE_COUNT=$((CURRENT_POOL - BALANCE_THRESHOLD))
  if [ "$REMOVE_COUNT" -le 0 ]; then
    echo "$(TS) [INFO]  池子未超出阈值，无需平衡"
  else
    echo "$(TS) [INFO]  需淘汰 ${REMOVE_COUNT} 个，保持池子在 ${BALANCE_THRESHOLD} 个..."
    PROTECT_IP1=$(awk 'NR==1{print $2}' "$WEIGHTED_OUT" 2>/dev/null)
    PROTECT_IP2=$(awk 'NR==2{print $2}' "$WEIGHTED_OUT" 2>/dev/null)
    PROTECT_IP3=$(grep "^IP3=" "$ROLES_FILE" 2>/dev/null | cut -d'=' -f2)
    echo "$(TS) [INFO]  保护DNS角色IP: [${PROTECT_IP1}] [${PROTECT_IP2}] [${PROTECT_IP3}]"

    WORST=$(awk '{
      ip=$1; n=NF;
      if(n>=4) w=$(n-2)+$(n-1)+($n*2);
      else if(n==3) w=$(n-1)+($n*2);
      else w=$n*2;
      printf "%s %.2f\n", ip, w
    }' "$HISTORY_FILE" | sort -k2,2n | head -n "$REMOVE_COUNT" | awk '{print $1}')

    ACTUAL_REMOVED=0
    while read -r BAD; do
      [ -z "$BAD" ] && continue
      if [ "$BAD" = "$PROTECT_IP1" ] || [ "$BAD" = "$PROTECT_IP2" ] || [ "$BAD" = "$PROTECT_IP3" ]; then
        echo "$(TS) [INFO]  跳过保护: $BAD"; continue
      fi
      sed -i "/^${BAD}$/d" "$ACCUM_FILE"
      sed -i "/^${BAD} /d" "$HISTORY_FILE"
      echo "$(TS) [INFO]  已淘汰: $BAD"
      ACTUAL_REMOVED=$((ACTUAL_REMOVED+1))
    done <<< "$WORST"
    echo "$(TS) [INFO]  实际淘汰 ${ACTUAL_REMOVED} 个，平衡后US池: $(wc -l < "$ACCUM_FILE") 个IP"
  fi
fi

awk '{
  ip=$1; n=NF;
  if(n>=4) w=$(n-2)+$(n-1)+($n*2);
  else if(n==3) w=$(n-1)+($n*2);
  else w=$n*2;
  print w, ip, $n
}' "$HISTORY_FILE" | sort -rn | while read -r W I S; do
  echo "$HEALTH_PASS_IPS" | grep -qx "$I" && echo "$W $I $S"
done > "$WEIGHTED_OUT"
echo "$(TS) [INFO]  平衡后加权榜已更新: $WEIGHTED_OUT"

echo "$ALL_SCORED" > "$SCORED_OUT"
FINAL=$(wc -l < "$ACCUM_FILE")
echo "============================================================"
echo "$(TS) US全流程完成！池: ${FINAL} 个IP"
echo "============================================================"
EOF



