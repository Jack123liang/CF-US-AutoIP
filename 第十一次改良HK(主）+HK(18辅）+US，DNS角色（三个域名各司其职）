if [ $EXIT_CODE -ne 0 ] || [ ! -f "$RESULT_CFST" ]; then
  echo "$(TS) [ERROR] 专项测速失败，恢复Clash后退出"
  /etc/init.d/openclash start 2>/dev/null; exit 1
fi

