# ---- 通用DNS同步函数 ----
dns_sync() {
  local ZONE="$1" DOMAIN_NAME="$2" DESC="$3"
  shift 3
  echo "$TS [INFO]  同步 ${DOMAIN_NAME}（${DESC}）"
  local ALL_IDS
  ALL_IDS=$(curl -s \
    "https://api.cloudflare.com/client/v4/zones/${ZONE}/dns_records?type=A&name=${DOMAIN_NAME}" \
    -H "Authorization: Bearer $API_TOKEN" \
    | jq -r ".result[].id" 2>/dev/null)
  for RID in $ALL_IDS; do
    [ -z "$RID" ] || [ "$RID" = "null" ] && continue
    curl -s -X DELETE \
      "https://api.cloudflare.com/client/v4/zones/${ZONE}/dns_records/$RID" \
      -H "Authorization: Bearer $API_TOKEN" > /dev/null
    echo "$TS [INFO]  已清理旧记录: $RID"
  done
  for TARGET_IP in "$@"; do
    [ -z "$TARGET_IP" ] && continue
    RES=$(curl -s -X POST \
      "https://api.cloudflare.com/client/v4/zones/${ZONE}/dns_records" \
      -H "Authorization: Bearer $API_TOKEN" \
      -H "Content-Type: application/json" \
      --data "{\"type\":\"A\",\"name\":\"${DOMAIN_NAME}\",\"content\":\"${TARGET_IP}\",\"ttl\":60,\"proxied\":false}")
    SUCCESS=$(echo "$RES" | jq -r '.success' 2>/dev/null)
    [ "$SUCCESS" = "true" ] \
      && echo "$TS [INFO]  DNS发布成功: ${DOMAIN_NAME} → $TARGET_IP" \
      || echo "$TS [ERROR] DNS发布失败: ${DOMAIN_NAME} → $TARGET_IP"
  done
}

