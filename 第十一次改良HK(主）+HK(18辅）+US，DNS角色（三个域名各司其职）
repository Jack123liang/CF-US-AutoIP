awk 'BEGIN{srand()}{print rand(),$0}' "$DATA_DIR/src2_us.tmp" | sort -n | cut -d' ' -f2- | head -"$HALF" > "$DATA_DIR/smp2_us.tmp"
cat "$DATA_DIR/smp1_us.tmp" "$DATA_DIR/smp2_us.tmp" \
