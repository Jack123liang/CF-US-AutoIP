  IFS='.' read -r a b c d <<< "$BASE"
  if [ "$PREFIX" -le 15 ]; then
    awk -v a="$a" 'BEGIN{srand();for(i=1;i<=54;i++){b=int(rand()*256);c=int(rand()*256);d=int(rand()*253)+1;print a"."b"."c"."d}}' >> "$DATA_DIR/src2_us.tmp"
  elif [ "$PREFIX" -le 17 ]; then
