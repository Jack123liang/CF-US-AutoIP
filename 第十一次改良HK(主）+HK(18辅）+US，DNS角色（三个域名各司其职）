if [ "$NEW_COUNT" -eq 0 ]; then
  echo "$(TS) [WARN]  无新IP，跳过入池"
  echo "0" > "$NEW_COUNT_FILE"
else
  if [ -f "$ACCUM_FILE" ] && [ -s "$ACCUM_FILE" ]; then
    BEFORE=$(wc -l < "$ACCUM_FILE")
    cat "$ACCUM_FILE" "$TEMP_FILE" | sort -u > "${ACCUM_FILE}.tmp"
    mv "${ACCUM_FILE}.tmp" "$ACCUM_FILE"
    AFTER=$(wc -l < "$ACCUM_FILE")
    ADDED=$((AFTER - BEFORE))
    echo "$(TS) [INFO]  合并去重: ${BEFORE} → ${AFTER} 个IP（净新增 ${ADDED} 个）"
  else
    cp "$TEMP_FILE" "$ACCUM_FILE"
    AFTER=$(wc -l < "$ACCUM_FILE"); ADDED=$AFTER
    echo "$(TS) [INFO]  初始化池，写入 ${AFTER} 个IP"
  fi
  echo "$ADDED" > "$NEW_COUNT_FILE"
